{
  "name": "badminton-scoreboard",
  "version": "1.0.0",
  "description": "Web-Based Badminton Scoreboard & Match Manager - BWF Style",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "pkg server.js --config pkg.config.json --targets node18-win-x64 --output dist/BadmintonScoreboard.exe",
    "build:all": "pkg server.js --config pkg.config.json --targets node18-win-x64,node18-macos-x64,node18-linux-x64 --output dist/BadmintonScoreboard"
  },
  "pkg": {
    "assets": [],
    "scripts": []
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "jspdf": "^4.2.1",
    "socket.io": "^4.7.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "pkg": "^5.8.1"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "keywords": [
    "badminton",
    "scoreboard",
    "bwf",
    "socket.io"
  ],
  "license": "MIT"
}
